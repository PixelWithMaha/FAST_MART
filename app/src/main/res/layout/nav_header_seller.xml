<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginBottom="30dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iv_profile_pic"
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:src="@drawable/ic_person"
            app:shapeAppearanceOverlay="@style/CircleImage"
            android:background="#FFE0B2"
            android:padding="4dp"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="12dp">
            <TextView
                android:id="@+id/tv_header_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ashfak Sayem"
                android:textStyle="bold"
                android:textColor="#212121"
                android:textSize="17sp" />
            <TextView
                android:id="@+id/tv_header_email"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ashfaksayem@gmail.com"
                android:textColor="#757575"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/menu_home"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@drawable/bg_menu_selected"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:layout_marginBottom="10dp">
        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_home"
            app:tint="@color/white" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="15dp"
            android:text="Home"
            android:textColor="@color/white"
            android:textStyle="bold" />
        <TextView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:background="@drawable/bg_badge_white"
            android:gravity="center"
            android:text="2"
            android:textSize="11sp"
            android:textColor="#7C4DFF" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/menu_orders"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:layout_marginBottom="10dp">
        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_history"
            app:tint="#424242" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="15dp"
            android:text="Order History"
            android:textColor="#424242"
            android:textStyle="bold" />
        <TextView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:background="@drawable/bg_badge_red"
            android:gravity="center"
            android:text="2"
            android:textSize="11sp"
            android:textColor="@color/white" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/menu_settings"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp">
        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_settings"
            app:tint="#424242" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="15dp"
            android:text="Account Setting"
            android:textColor="#424242"
            android:textStyle="bold" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/colour_scheme"
        android:textStyle="bold"
        android:textColor="#424242"
        android:layout_marginBottom="10dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_theme_toggle"
        android:padding="4dp"
        android:orientation="horizontal">
        <TextView
            android:id="@+id/btn_light"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_theme_btn_active"
            android:gravity="center"
            android:text="Light"
            android:textColor="#424242"
            android:drawableStart="@drawable/ic_theme_sum"
            android:paddingStart="15dp"/>
        <TextView
            android:id="@+id/btn_dark"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Dark"
            android:textColor="#757575"
            android:drawableStart="@drawable/ic_history"
            android:paddingStart="15dp"/>
    </LinearLayout>
</LinearLayout>